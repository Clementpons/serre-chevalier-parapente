# ─────────────────────────────────────────────────────────────────────────────
# Fichier de configuration pour le script de migration
# Copier ce fichier en .env.migration et remplir les valeurs
# ⚠️  Ne jamais committer .env.migration (il contient des credentials de prod)
# ─────────────────────────────────────────────────────────────────────────────

# Ancienne BDD Supabase (READ ONLY – ne jamais écrire ici)
# → Récupérer depuis le dashboard Supabase : Settings > Database > Connection string
# → Utiliser la "Direct connection" (pas le "Transaction pooler")
OLD_DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Nouvelle BDD (destination de la migration)
# → Copier depuis apps/backoffice/.env.local
DATABASE_URL=postgresql://...
DIRECT_URL=postgresql://...

# Mot de passe temporaire assigné aux utilisateurs migrés
# Chaque utilisateur devra le changer après sa première connexion
TEMP_PASSWORD=ChangeMe2026!
