# Database
# Local dev: Docker PostgreSQL (docker compose up -d)
DATABASE_URL=""
DIRECT_URL=""

# App
NEXT_PUBLIC_APP_URL=""

# better-auth
BETTER_AUTH_URL=""
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# Public API key (must match NEXT_PUBLIC_API_KEY in apps/front)
# Generate with: openssl rand -hex 32
PUBLIC_API_KEY=""

# Stripe (use TEST keys locally — NEVER live keys in .env.local)
STRIPE_SECRET_KEY="sk_test_..."
# Get from: stripe listen --forward-to localhost:3001/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET="whsec_..."

# Email (Resend - https://resend.com)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL=""
ADMIN_EMAIL=""

# SMS Twilio (optional - set TWILIO_SIMULATION=true in dev)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
TWILIO_SIMULATION="true"
